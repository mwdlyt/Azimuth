<ui:FluentWindow x:Class="Azimuth.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Settings"
        Height="520" Width="440"
        MinHeight="480" MinWidth="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0F0F17"
        ExtendsContentIntoTitleBar="True">

    <ui:FluentWindow.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#2DD4BF"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style x:Key="SettingLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F0F0F5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="MutedLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#5A5A72"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Settings" ShowMaximize="False" ShowMinimize="False"/>

        <Border Grid.Row="1" Background="#0F0F17" Padding="24,8,24,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <!-- Audio Section -->
                        <TextBlock Text="A U D I O" Style="{StaticResource SectionHeader}"/>
                        <Border Background="#1A1A28" CornerRadius="10" Padding="14"
                                BorderBrush="#2A2A3C" BorderThickness="1" Margin="0,0,0,16">
                            <StackPanel>
                                <!-- Sample Rate -->
                                <DockPanel Margin="0,0,0,12">
                                    <TextBlock Text="Sample Rate" Style="{StaticResource SettingLabel}" DockPanel.Dock="Left"/>
                                    <ComboBox x:Name="SampleRateCombo" Width="120" HorizontalAlignment="Right"
                                              SelectedValuePath="Tag">
                                        <ComboBoxItem Content="22050 Hz" Tag="22050"/>
                                        <ComboBoxItem Content="44100 Hz" Tag="44100"/>
                                        <ComboBoxItem Content="48000 Hz" Tag="48000"/>
                                    </ComboBox>
                                </DockPanel>

                                <!-- Distance Falloff -->
                                <DockPanel Margin="0,0,0,4">
                                    <TextBlock Text="Distance Falloff" Style="{StaticResource SettingLabel}" DockPanel.Dock="Left"/>
                                    <TextBlock x:Name="FalloffValueText" Style="{StaticResource MutedLabel}"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </DockPanel>
                                <Slider x:Name="FalloffSlider" Minimum="1" Maximum="20"
                                        TickFrequency="0.5" IsSnapToTickEnabled="True"
                                        ValueChanged="FalloffSlider_ValueChanged"
                                        Margin="0,0,0,4"/>
                            </StackPanel>
                        </Border>

                        <!-- Canvas Section -->
                        <TextBlock Text="C A N V A S" Style="{StaticResource SectionHeader}"/>
                        <Border Background="#1A1A28" CornerRadius="10" Padding="14"
                                BorderBrush="#2A2A3C" BorderThickness="1" Margin="0,0,0,16">
                            <StackPanel>
                                <!-- Grid Size -->
                                <DockPanel Margin="0,0,0,4">
                                    <TextBlock Text="Grid Size" Style="{StaticResource SettingLabel}" DockPanel.Dock="Left"/>
                                    <TextBlock x:Name="GridSizeValueText" Style="{StaticResource MutedLabel}"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </DockPanel>
                                <Slider x:Name="GridSizeSlider" Minimum="10" Maximum="100"
                                        TickFrequency="5" IsSnapToTickEnabled="True"
                                        ValueChanged="GridSizeSlider_ValueChanged"
                                        Margin="0,0,0,12"/>

                                <!-- Snap Default -->
                                <CheckBox x:Name="SnapDefaultCheck" Content="Enable snap-to-grid by default"
                                          Foreground="#F0F0F5" FontSize="12"/>
                            </StackPanel>
                        </Border>

                        <!-- General Section -->
                        <TextBlock Text="G E N E R A L" Style="{StaticResource SectionHeader}"/>
                        <Border Background="#1A1A28" CornerRadius="10" Padding="14"
                                BorderBrush="#2A2A3C" BorderThickness="1" Margin="0,0,0,8">
                            <StackPanel>
                                <CheckBox x:Name="OpenLastSceneCheck" Content="Open last scene on startup"
                                          Foreground="#F0F0F5" FontSize="12" Margin="0,0,0,12"/>
                                <ui:Button Content="Clear Recent Files" Appearance="Danger"
                                           Click="ClearRecents_Click" FontSize="11"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- OK / Cancel buttons -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                    <ui:Button Content="Cancel" Appearance="Secondary" Click="Cancel_Click"
                               Margin="0,0,8,0" Width="80"/>
                    <ui:Button Content="OK" Appearance="Primary" Click="OK_Click"
                               Width="80"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
