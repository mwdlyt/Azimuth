<UserControl x:Class="Azimuth.Controls.TimelinePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Azimuth.Converters"
             Background="#0D0D0F">

    <UserControl.Resources>
        <converters:HexToColorBrushConverter x:Key="HexToBrush"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#161622" Padding="12,6">
            <TextBlock Text="T I M E L I N E" FontSize="10" FontWeight="Bold" Foreground="#6B6B80"/>
        </Border>

        <!-- Source Timeline Rows -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="#0D0D0F">
            <ItemsControl x:Name="TimelineItems" ItemsSource="{Binding Sources}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#111118" BorderBrush="#1A1A2E" BorderThickness="0,0,0,1"
                                Padding="0" Height="40">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Source info -->
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="10,0,8,0"
                                            VerticalAlignment="Center">
                                    <Ellipse Width="8" Height="8" Margin="0,0,6,0"
                                             Fill="{Binding Color, Converter={StaticResource HexToBrush}}"/>
                                    <TextBlock Text="{Binding Name}" Foreground="#E8E8F0" FontSize="11"
                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                               MaxWidth="90"/>
                                </StackPanel>

                                <!-- Waveform track area -->
                                <Canvas x:Name="WaveformCanvas" Grid.Column="1" Background="#161622"
                                        ClipToBounds="True"
                                        MouseLeftButtonDown="WaveformCanvas_MouseLeftButtonDown"
                                        MouseMove="WaveformCanvas_MouseMove"
                                        MouseLeftButtonUp="WaveformCanvas_MouseLeftButtonUp"
                                        Tag="{Binding}"
                                        SizeChanged="WaveformCanvas_SizeChanged"
                                        Loaded="WaveformCanvas_Loaded"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
