<UserControl x:Class="Azimuth.Controls.OrbitPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             Width="260">
    <Border Background="#161622" Padding="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header: source name + color dot -->
            <DockPanel Grid.Row="0" Margin="0,0,0,16">
                <Ellipse Width="10" Height="10" Margin="0,0,8,0" DockPanel.Dock="Left"
                         x:Name="ColorDot"/>
                <TextBlock x:Name="SourceNameText" Text="Source"
                           Foreground="#E8E8F0" FontSize="13" FontWeight="SemiBold"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
            </DockPanel>

            <!-- Enable Orbit Toggle -->
            <Border Grid.Row="1" Background="#1A1A2E" CornerRadius="6" Padding="12,8" Margin="0,0,0,12">
                <DockPanel>
                    <TextBlock Text="Enable Orbit" Foreground="#E8E8F0" FontSize="12"
                               VerticalAlignment="Center" DockPanel.Dock="Left"/>
                    <CheckBox x:Name="OrbitToggle" HorizontalAlignment="Right"
                              Checked="OrbitToggle_Changed" Unchecked="OrbitToggle_Changed"/>
                </DockPanel>
            </Border>

            <!-- Orbit Settings (visible only when orbit is enabled) -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                          x:Name="OrbitSettingsPanel" Visibility="Collapsed">
                <StackPanel>
                    <!-- ═══ Shape Section ═══ -->
                    <TextBlock Text="S H A P E" FontSize="10" FontWeight="Bold"
                               Foreground="#6B6B80" Margin="0,0,0,8"/>

                    <!-- Radius X -->
                    <DockPanel Margin="0,0,0,4">
                        <TextBlock Text="Radius X" Foreground="#9090A8" FontSize="11"
                                   VerticalAlignment="Center" DockPanel.Dock="Left"/>
                        <TextBlock x:Name="RadiusXValue" Foreground="#E8E8F0" FontSize="11"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                   DockPanel.Dock="Right"/>
                    </DockPanel>
                    <Slider x:Name="RadiusXSlider" Minimum="10" Maximum="400" Value="100"
                            TickFrequency="1" IsSnapToTickEnabled="True"
                            ValueChanged="RadiusXSlider_ValueChanged" Margin="0,0,0,8"/>

                    <!-- Link toggle -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8" HorizontalAlignment="Center">
                        <ui:Button x:Name="LinkButton" Content="🔗 Linked"
                                   Appearance="Primary" FontSize="10" Padding="8,4"
                                   Click="LinkButton_Click" ToolTip="Link radii for circular orbit"/>
                    </StackPanel>

                    <!-- Radius Y -->
                    <DockPanel Margin="0,0,0,4">
                        <TextBlock Text="Radius Y" Foreground="#9090A8" FontSize="11"
                                   VerticalAlignment="Center" DockPanel.Dock="Left"/>
                        <TextBlock x:Name="RadiusYValue" Foreground="#E8E8F0" FontSize="11"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                   DockPanel.Dock="Right"/>
                    </DockPanel>
                    <Slider x:Name="RadiusYSlider" Minimum="10" Maximum="400" Value="100"
                            TickFrequency="1" IsSnapToTickEnabled="True"
                            ValueChanged="RadiusYSlider_ValueChanged" Margin="0,0,0,16"/>

                    <!-- ═══ Motion Section ═══ -->
                    <TextBlock Text="M O T I O N" FontSize="10" FontWeight="Bold"
                               Foreground="#6B6B80" Margin="0,0,0,8"/>

                    <!-- Speed -->
                    <DockPanel Margin="0,0,0,4">
                        <TextBlock Text="Speed" Foreground="#9090A8" FontSize="11"
                                   VerticalAlignment="Center" DockPanel.Dock="Left"/>
                        <TextBlock x:Name="SpeedValue" Foreground="#E8E8F0" FontSize="11"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                   DockPanel.Dock="Right"/>
                    </DockPanel>
                    <Slider x:Name="SpeedSlider" Minimum="1" Maximum="360" Value="45"
                            TickFrequency="1" IsSnapToTickEnabled="True"
                            ValueChanged="SpeedSlider_ValueChanged" Margin="0,0,0,12"/>

                    <!-- Direction -->
                    <DockPanel Margin="0,0,0,16">
                        <TextBlock Text="Direction" Foreground="#9090A8" FontSize="11"
                                   VerticalAlignment="Center" DockPanel.Dock="Left"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <ui:Button x:Name="CwButton" Content="CW" FontSize="10"
                                       Padding="10,4" Margin="0,0,4,0"
                                       Click="CwButton_Click"/>
                            <ui:Button x:Name="CcwButton" Content="CCW" FontSize="10"
                                       Padding="10,4"
                                       Click="CcwButton_Click"/>
                        </StackPanel>
                    </DockPanel>

                    <!-- ═══ Position Section ═══ -->
                    <TextBlock Text="P O S I T I O N" FontSize="10" FontWeight="Bold"
                               Foreground="#6B6B80" Margin="0,0,0,8"/>

                    <DockPanel Margin="0,0,0,4">
                        <TextBlock Text="Center X" Foreground="#9090A8" FontSize="11"
                                   VerticalAlignment="Center" DockPanel.Dock="Left"/>
                        <TextBlock x:Name="CenterXValue" Foreground="#E8E8F0" FontSize="11"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                   DockPanel.Dock="Right"/>
                    </DockPanel>
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="Center Y" Foreground="#9090A8" FontSize="11"
                                   VerticalAlignment="Center" DockPanel.Dock="Left"/>
                        <TextBlock x:Name="CenterYValue" Foreground="#E8E8F0" FontSize="11"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                   DockPanel.Dock="Right"/>
                    </DockPanel>

                    <ui:Button Content="Reset Center" Appearance="Secondary" FontSize="11"
                               HorizontalAlignment="Stretch" Margin="0,0,0,8"
                               Click="ResetCenterButton_Click"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
