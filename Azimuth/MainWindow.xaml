<ui:FluentWindow x:Class="Azimuth.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:controls="clr-namespace:Azimuth.Controls"
        xmlns:converters="clr-namespace:Azimuth.Converters"
        Title="{Binding WindowTitle}"
        Height="800" Width="1280"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#0D0D0F"
        ExtendsContentIntoTitleBar="True">

    <ui:FluentWindow.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:HexToColorBrushConverter x:Key="HexToBrush"/>
        <converters:FloatToPercentConverter x:Key="FloatToPercent"/>

        <!-- Muted text style -->
        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6B6B80"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <ui:TitleBar Grid.Row="0" Title="Azimuth" ShowMaximize="True" ShowMinimize="True">
        </ui:TitleBar>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Sidebar -->
            <Border Grid.Column="0" Background="#161622" CornerRadius="0" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- App Title -->
                    <StackPanel Grid.Row="0" Margin="0,4,0,20">
                        <TextBlock Text="&#x2726; Azimuth" FontSize="22" FontWeight="Bold" Foreground="#7C5CFC"/>
                        <TextBlock Text="Spatial Audio Placement" Style="{StaticResource MutedText}" Margin="0,2,0,0"/>
                    </StackPanel>

                    <!-- Toolbar Buttons -->
                    <WrapPanel Grid.Row="1" Margin="0,0,0,16">
                        <ui:Button Content="New" Icon="{ui:SymbolIcon DocumentAdd24}" Appearance="Secondary"
                                   Command="{Binding NewSceneCommand}" Margin="0,0,4,4" FontSize="11"/>
                        <ui:Button Content="Open" Icon="{ui:SymbolIcon FolderOpen24}" Appearance="Secondary"
                                   Command="{Binding OpenCommand}" Margin="0,0,4,4" FontSize="11"/>
                        <ui:Button Content="Save" Icon="{ui:SymbolIcon Save24}" Appearance="Secondary"
                                   Command="{Binding SaveCommand}" Margin="0,0,4,4" FontSize="11"/>
                        <ui:Button Content="WAV" Icon="{ui:SymbolIcon ArrowDownload24}" Appearance="Secondary"
                                   Command="{Binding ExportWavCommand}" Margin="0,0,4,4" FontSize="11"/>
                        <ui:Button Content="MP3" Icon="{ui:SymbolIcon ArrowDownload24}" Appearance="Secondary"
                                   Command="{Binding ExportMp3Command}" Margin="0,0,4,4" FontSize="11"/>
                    </WrapPanel>

                    <!-- Play/Stop + Timeline Toggle -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,16">
                        <ui:Button Content="Play All" Icon="{ui:SymbolIcon Play24}" Appearance="Primary"
                                   Command="{Binding PlayAllCommand}" Margin="0,0,8,0"
                                   Visibility="{Binding IsPlaying, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"/>
                        <ui:Button Content="Stop" Icon="{ui:SymbolIcon Stop24}" Appearance="Caution"
                                   Command="{Binding StopAllCommand}" Margin="0,0,8,0"
                                   Visibility="{Binding IsPlaying, Converter={StaticResource BoolToVis}}"/>
                        <ui:Button Icon="{ui:SymbolIcon SlideText24}" Appearance="Secondary"
                                   Command="{Binding ToggleTimelinePanelCommand}" Margin="0,0,0,0"
                                   Padding="4" FontSize="10"
                                   ToolTip="Toggle Timeline"/>
                    </StackPanel>

                    <!-- Source List -->
                    <Grid Grid.Row="3">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="S O U R C E S" FontSize="10" FontWeight="Bold"
                                   Foreground="#6B6B80" Margin="0,0,0,8"/>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Sources}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#1A1A2E" CornerRadius="8" Padding="10" Margin="0,0,0,6">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <!-- Name row -->
                                                <DockPanel Grid.Row="0">
                                                    <Ellipse Width="10" Height="10" Margin="0,0,8,0"
                                                             Fill="{Binding Color, Converter={StaticResource HexToBrush}}"
                                                             DockPanel.Dock="Left"/>
                                                    <TextBlock Text="{Binding Name}" Foreground="#E8E8F0"
                                                               FontSize="12" FontWeight="SemiBold"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </DockPanel>

                                                <!-- Distance/Pan info -->
                                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,4,0,4">
                                                    <TextBlock Style="{StaticResource MutedText}">
                                                        <Run Text="Dist: "/><Run Text="{Binding DistancePercent, Mode=OneWay}"/>
                                                        <Run Text="  Pan: "/><Run Text="{Binding PanDisplay, Mode=OneWay}"/>
                                                    </TextBlock>
                                                </StackPanel>

                                                <!-- Controls row -->
                                                <DockPanel Grid.Row="2">
                                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                                        <!-- Play/Pause per source -->
                                                        <ui:Button Icon="{ui:SymbolIcon Play24}" Appearance="Secondary"
                                                                   Command="{Binding DataContext.ToggleSourcePlayPauseCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                   CommandParameter="{Binding}"
                                                                   Padding="4" Margin="2,0" FontSize="10"
                                                                   ToolTip="Play"
                                                                   Visibility="{Binding IsPlaying, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"/>
                                                        <ui:Button Icon="{ui:SymbolIcon Pause24}" Appearance="Secondary"
                                                                   Command="{Binding DataContext.ToggleSourcePlayPauseCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                   CommandParameter="{Binding}"
                                                                   Padding="4" Margin="2,0" FontSize="10"
                                                                   ToolTip="Pause"
                                                                   Visibility="{Binding IsPlaying, Converter={StaticResource BoolToVis}}"/>
                                                        <ui:Button Icon="{ui:SymbolIcon SpeakerMute24}" Appearance="Secondary"
                                                                   Command="{Binding DataContext.ToggleMuteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                   CommandParameter="{Binding}"
                                                                   Padding="4" Margin="2,0" FontSize="10"
                                                                   ToolTip="Mute"/>
                                                        <ui:Button Icon="{ui:SymbolIcon Headphones24}" Appearance="Secondary"
                                                                   Command="{Binding DataContext.ToggleSoloCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                   CommandParameter="{Binding}"
                                                                   Padding="4" Margin="2,0" FontSize="10"
                                                                   ToolTip="Solo"/>
                                                        <ui:Button Icon="{ui:SymbolIcon Delete24}" Appearance="Danger"
                                                                   Command="{Binding DataContext.RemoveSourceCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                   CommandParameter="{Binding}"
                                                                   Padding="4" Margin="2,0" FontSize="10"
                                                                   ToolTip="Remove"/>
                                                    </StackPanel>

                                                    <!-- Volume slider -->
                                                    <Slider Minimum="0" Maximum="100"
                                                            Value="{Binding BaseVolume, Converter={StaticResource FloatToPercent}}"
                                                            Margin="0,0,8,0" VerticalAlignment="Center"
                                                            ValueChanged="VolumeSlider_ValueChanged"
                                                            Tag="{Binding}"/>
                                                </DockPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Empty state -->
                        <TextBlock Grid.Row="1" Text="Drop audio files (.wav, .mp3)&#x0a;onto the canvas to begin"
                                   Style="{StaticResource MutedText}" TextAlignment="Center"
                                   VerticalAlignment="Center" LineHeight="20"
                                   Visibility="{Binding Sources.Count, Converter={StaticResource BoolToVis}, ConverterParameter=Invert, FallbackValue=Visible}"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- Spatial Canvas -->
            <controls:SpatialCanvas x:Name="SpatialCanvas" Grid.Column="1"
                                     DataContext="{Binding}"
                                     Margin="8"/>

        </Grid>

        <!-- Timeline Panel (collapsible) -->
        <controls:TimelinePanel Grid.Row="2" x:Name="TimelinePanel"
                                 DataContext="{Binding}"
                                 Height="160"
                                 Visibility="{Binding IsTimelinePanelVisible, Converter={StaticResource BoolToVis}}"/>

        <!-- Status Bar -->
        <Border Grid.Row="3" Background="#161622" Padding="12,6">
            <DockPanel>
                <TextBlock Text="{Binding StatusText}" Foreground="#6B6B80" FontSize="11"
                           DockPanel.Dock="Left"/>
                <TextBlock Text="v1.0" Foreground="#3A3A50" FontSize="11"
                           DockPanel.Dock="Right" HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
