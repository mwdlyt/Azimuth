<ui:FluentWindow x:Class="Azimuth.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:controls="clr-namespace:Azimuth.Controls"
        xmlns:converters="clr-namespace:Azimuth.Converters"
        Title="{Binding WindowTitle}"
        Height="800" Width="1280"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#0F0F17"
        ExtendsContentIntoTitleBar="True">

    <ui:FluentWindow.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:HexToColorBrushConverter x:Key="HexToBrush"/>
        <converters:FloatToPercentConverter x:Key="FloatToPercent"/>

        <!-- Muted text style -->
        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#5A5A72"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <ui:TitleBar Grid.Row="0" Title="Azimuth" ShowMaximize="True" ShowMinimize="True">
        </ui:TitleBar>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Left Sidebar -->
            <Border Grid.Column="0" Background="#151521" CornerRadius="0" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- App Title -->
                    <StackPanel Grid.Row="0" Margin="0,4,0,20">
                        <TextBlock Text="&#x2726; Azimuth" FontSize="22" FontWeight="Bold" Foreground="#2DD4BF"/>
                        <TextBlock Text="Spatial Audio Placement" Style="{StaticResource MutedText}" Margin="0,2,0,0"/>
                    </StackPanel>

                    <!-- Toolbar Buttons -->
                    <WrapPanel Grid.Row="1" Margin="0,0,0,16">
                        <ui:Button Content="New" Icon="{ui:SymbolIcon DocumentAdd24}" Appearance="Secondary"
                                   Command="{Binding NewSceneCommand}" Margin="0,0,4,4" FontSize="11"/>
                        <ui:Button Content="Open" Icon="{ui:SymbolIcon FolderOpen24}" Appearance="Secondary"
                                   Command="{Binding OpenCommand}" Margin="0,0,4,4" FontSize="11"/>
                        <ui:Button Content="Save" Icon="{ui:SymbolIcon Save24}" Appearance="Secondary"
                                   Command="{Binding SaveCommand}" Margin="0,0,4,4" FontSize="11"/>
                        <ui:Button Content="WAV" Icon="{ui:SymbolIcon ArrowDownload24}" Appearance="Secondary"
                                   Command="{Binding ExportWavCommand}" Margin="0,0,4,4" FontSize="11"/>
                        <ui:Button Content="MP3" Icon="{ui:SymbolIcon ArrowDownload24}" Appearance="Secondary"
                                   Command="{Binding ExportMp3Command}" Margin="0,0,4,4" FontSize="11"/>
                        <ui:Button Icon="{ui:SymbolIcon Settings24}" Appearance="Secondary"
                                   Command="{Binding OpenSettingsCommand}" Margin="0,0,4,4"
                                   Padding="4" FontSize="10" ToolTip="Settings"/>
                    </WrapPanel>

                    <!-- Play/Stop + Timeline Toggle -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,16">
                        <ui:Button Content="Play All" Icon="{ui:SymbolIcon Play24}" Appearance="Primary"
                                   Command="{Binding PlayAllCommand}" Margin="0,0,8,0"
                                   Visibility="{Binding IsPlaying, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"/>
                        <ui:Button Content="Stop" Icon="{ui:SymbolIcon Stop24}" Appearance="Caution"
                                   Command="{Binding StopAllCommand}" Margin="0,0,8,0"
                                   Visibility="{Binding IsPlaying, Converter={StaticResource BoolToVis}}"/>
                        <ui:Button Icon="{ui:SymbolIcon SlideText24}" Appearance="Secondary"
                                   Command="{Binding ToggleTimelinePanelCommand}" Margin="0,0,8,0"
                                   Padding="4" FontSize="10"
                                   ToolTip="Toggle Timeline"/>
                        <!-- Grid Off state -->
                        <ui:Button Icon="{ui:SymbolIcon Grid24}" Appearance="Secondary"
                                   Command="{Binding ToggleSnapToGridCommand}"
                                   Padding="4" Margin="0,0,0,0"
                                   ToolTip="Enable Snap to Grid"
                                   Visibility="{Binding IsSnapToGridEnabled, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"/>
                        <!-- Grid On state -->
                        <ui:Button Icon="{ui:SymbolIcon Grid24}" Appearance="Primary"
                                   Command="{Binding ToggleSnapToGridCommand}"
                                   Padding="4" Margin="0,0,8,0"
                                   ToolTip="Disable Snap to Grid"
                                   Visibility="{Binding IsSnapToGridEnabled, Converter={StaticResource BoolToVis}}"/>
                        <!-- Orbit Panel Off -->
                        <ui:Button Icon="{ui:SymbolIcon ArrowRotateClockwise24}" Appearance="Secondary"
                                   Command="{Binding ToggleOrbitPanelCommand}"
                                   Padding="4" Margin="0,0,0,0"
                                   ToolTip="Show Orbit Panel"
                                   Visibility="{Binding IsOrbitPanelVisible, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"/>
                        <!-- Orbit Panel On -->
                        <ui:Button Icon="{ui:SymbolIcon ArrowRotateClockwise24}" Appearance="Primary"
                                   Command="{Binding ToggleOrbitPanelCommand}"
                                   Padding="4" Margin="0,0,0,0"
                                   ToolTip="Hide Orbit Panel"
                                   Visibility="{Binding IsOrbitPanelVisible, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>

                    <!-- Recent Files (hidden when empty) -->
                    <StackPanel Grid.Row="3" x:Name="RecentFilesPanel"
                                Margin="0,0,0,12"
                                Visibility="{Binding RecentFiles.Count, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                        <TextBlock Text="R E C E N T" FontSize="10" FontWeight="Bold"
                                   Foreground="#5A5A72" Margin="0,0,0,6"/>
                        <ItemsControl ItemsSource="{Binding RecentFiles}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="Transparent" Cursor="Hand" Margin="0,0,0,2"
                                            MouseLeftButtonUp="RecentFile_Click" Tag="{Binding}">
                                        <TextBlock Text="{Binding Converter={x:Static converters:PathToFilenameConverter.Instance}}"
                                                   Foreground="#A0A0B4" FontSize="11"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding}"
                                                   Padding="4,3">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Foreground" Value="#F0F0F5"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Source List -->
                    <Grid Grid.Row="4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="S O U R C E S" FontSize="10" FontWeight="Bold"
                                   Foreground="#5A5A72" Margin="0,0,0,8"/>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ListBox x:Name="SourceListBox" ItemsSource="{Binding Sources}"
                                     Background="Transparent" BorderThickness="0"
                                     HorizontalContentAlignment="Stretch"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     PreviewMouseLeftButtonDown="SourceList_PreviewMouseLeftButtonDown"
                                     PreviewMouseMove="SourceList_PreviewMouseMove"
                                     Drop="SourceList_Drop"
                                     DragOver="SourceList_DragOver"
                                     AllowDrop="True">
                                <ListBox.Resources>
                                    <!-- Remove default selection highlight -->
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#F0F0F5"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent"/>
                                </ListBox.Resources>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <ContentPresenter/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="10" Padding="12" Margin="0,0,0,8"
                                                Cursor="Hand"
                                                MouseLeftButtonDown="SourceRow_MouseLeftButtonDown"
                                                Tag="{Binding}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#1A1A28"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                    <Setter Property="BorderBrush" Value="#2A2A3C"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="BorderBrush" Value="{Binding Color, Converter={StaticResource HexToBrush}}"/>
                                                            <Setter Property="Background" Value="#222234"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <!-- Name row -->
                                                <DockPanel Grid.Row="0">
                                                    <Ellipse Width="10" Height="10" Margin="0,0,8,0"
                                                             Fill="{Binding Color, Converter={StaticResource HexToBrush}}"
                                                             DockPanel.Dock="Left"/>
                                                    <TextBlock Text="{Binding Name}" Foreground="#F0F0F5"
                                                               FontSize="12" FontWeight="SemiBold"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </DockPanel>

                                                <!-- Distance/Pan info -->
                                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,4,0,4">
                                                    <TextBlock Style="{StaticResource MutedText}">
                                                        <Run Text="Dist: "/><Run Text="{Binding DistancePercent, Mode=OneWay}"/>
                                                        <Run Text="  Pan: "/><Run Text="{Binding PanDisplay, Mode=OneWay}"/>
                                                    </TextBlock>
                                                </StackPanel>

                                                <!-- Controls row -->
                                                <DockPanel Grid.Row="2">
                                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                                        <!-- Play/Pause per source -->
                                                        <ui:Button Icon="{ui:SymbolIcon Play24}" Appearance="Secondary"
                                                                   Command="{Binding DataContext.ToggleSourcePlayPauseCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                                   CommandParameter="{Binding}"
                                                                   Padding="4" Margin="2,0" FontSize="10"
                                                                   ToolTip="Play"
                                                                   Visibility="{Binding IsPlaying, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"/>
                                                        <ui:Button Icon="{ui:SymbolIcon Pause24}" Appearance="Secondary"
                                                                   Command="{Binding DataContext.ToggleSourcePlayPauseCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                                   CommandParameter="{Binding}"
                                                                   Padding="4" Margin="2,0" FontSize="10"
                                                                   ToolTip="Pause"
                                                                   Visibility="{Binding IsPlaying, Converter={StaticResource BoolToVis}}"/>
                                                        <ui:Button Icon="{ui:SymbolIcon SpeakerMute24}" Appearance="Secondary"
                                                                   Command="{Binding DataContext.ToggleMuteCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                                   CommandParameter="{Binding}"
                                                                   Padding="4" Margin="2,0" FontSize="10"
                                                                   ToolTip="Mute"/>
                                                        <ui:Button Icon="{ui:SymbolIcon Headphones24}" Appearance="Secondary"
                                                                   Command="{Binding DataContext.ToggleSoloCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                                   CommandParameter="{Binding}"
                                                                   Padding="4" Margin="2,0" FontSize="10"
                                                                   ToolTip="Solo"/>
                                                        <ui:Button Icon="{ui:SymbolIcon Delete24}" Appearance="Danger"
                                                                   Command="{Binding DataContext.RemoveSourceCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                                   CommandParameter="{Binding}"
                                                                   Padding="4" Margin="2,0" FontSize="10"
                                                                   ToolTip="Remove"/>
                                                    </StackPanel>

                                                    <!-- Volume slider -->
                                                    <Slider Minimum="0" Maximum="100"
                                                            Value="{Binding BaseVolume, Converter={StaticResource FloatToPercent}}"
                                                            Margin="0,0,8,0" VerticalAlignment="Center"
                                                            ValueChanged="VolumeSlider_ValueChanged"
                                                            Tag="{Binding}"/>
                                                </DockPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </ScrollViewer>

                        <!-- Empty state -->
                        <TextBlock Grid.Row="1" Text="Drop audio files (.wav, .mp3)&#x0a;onto the canvas to begin"
                                   Style="{StaticResource MutedText}" TextAlignment="Center"
                                   VerticalAlignment="Center" LineHeight="20"
                                   Visibility="{Binding Sources.Count, Converter={StaticResource BoolToVis}, ConverterParameter=Invert, FallbackValue=Visible}"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- Spatial Canvas -->
            <controls:SpatialCanvas x:Name="SpatialCanvas" Grid.Column="1"
                                     DataContext="{Binding}"
                                     Margin="8"/>

            <!-- Orbit Panel (right sidebar) -->
            <controls:OrbitPanel x:Name="OrbitPanel" Grid.Column="2"
                                  Visibility="{Binding IsOrbitPanelVisible, Converter={StaticResource BoolToVis}}"/>

        </Grid>

        <!-- Timeline Panel (collapsible) -->
        <controls:TimelinePanel Grid.Row="2" x:Name="TimelinePanel"
                                 DataContext="{Binding}"
                                 Height="160"
                                 Visibility="{Binding IsTimelinePanelVisible, Converter={StaticResource BoolToVis}}"/>

        <!-- Status Bar -->
        <Border Grid.Row="3" Background="#151521" Padding="12,6">
            <DockPanel>
                <TextBlock Text="{Binding StatusText}" Foreground="#5A5A72" FontSize="11"
                           DockPanel.Dock="Left"/>
                <TextBlock Text="v1.0" Foreground="#5A5A72" FontSize="11"
                           DockPanel.Dock="Right" HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
